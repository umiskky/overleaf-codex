# Copy this file to .env.e2e.local and fill in values locally.
# .env.e2e.local is ignored by Git and must never be committed.

# Set to 1 to enable real Overleaf E2E tests.
OLCX_E2E_ENABLE_REAL=0

# Overleaf session cookie from a browser where the test account is already logged in.
OLCX_E2E_OVERLEAF_SESSION=

# Dedicated disposable Overleaf project id for E2E tests.
OLCX_E2E_PROJECT_ID=

# Optional metadata for local status output and documentation.
OLCX_E2E_ACCOUNT_LABEL=
OLCX_E2E_PROJECT_URL=
